# Proteção contra acesso a arquivos sensíveis
# Bloquear acesso a arquivos de backup e configuração

<FilesMatch "\.(sql|zip|tar|gz|rar|7z|bak|backup|env|log)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloquear acesso a diretórios específicos
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Bloquear acesso a arquivos de backup
    RewriteRule ^.*\.(sql|zip|tar|gz|rar|7z|bak|backup)$ - [F,L]
    
    # Bloquear acesso a arquivos .env
    RewriteRule ^.*\.env$ - [F,L]
    
    # Bloquear acesso a diretórios de backup
    RewriteRule ^backups?/ - [F,L]
    
    # Bloquear acesso a arquivos de log
    RewriteRule ^.*\.log$ - [F,L]
</IfModule>

# Desabilitar listagem de diretórios
Options -Indexes

# Proteção adicional
<IfModule mod_headers.c>
    # Prevenir hotlinking
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
